# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false

# ── Database (SQLite inside Docker volume) ────────────────────────────────────
DATABASE_URL=sqlite:////app/data/emotion_app.db

# ── Auth ──────────────────────────────────────────────────────────────────────
# IMPORTANT: change this to a random 32+ char string in production
SECRET_KEY=change-this-secret-key-in-production-min-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── File Storage ──────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads/audio
MAX_AUDIO_SIZE_MB=50

# ── Whisper ───────────────────────────────────────────────────────────────────
# local  → runs openai-whisper in-process (uses WHISPER_MODEL)
# openai → calls OpenAI Whisper API (needs OPENAI_API_KEY)
WHISPER_PROVIDER=local
WHISPER_MODEL=base
WHISPER_DEVICE=cpu         # cpu | cuda (set cuda if GPU available)

# ── LLM ───────────────────────────────────────────────────────────────────────
# ollama → calls local Ollama service at OLLAMA_BASE_URL
# openai → calls OpenAI chat API (needs OPENAI_API_KEY)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3:8b

# ── OpenAI (only needed when WHISPER_PROVIDER=openai or LLM_PROVIDER=openai) ──
OPENAI_API_KEY=

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list handled by docker-compose env; adjust for production
CORS_ORIGINS=["http://localhost:5173","http://localhost"]
